{
  "name": "cnarios-playwright",
  "version": "1.0.0",
  "description": "Challenges from the website cnarios.com",
  "main": "index.js",
  "scripts": {
    "clean:reports": "rm -rf playwright-report/*",
    "pretest:e2e": "npm run clean:reports",
    "test:e2e": "npx playwright test",
    "test:e2e:staging": "BASE_URL=https://cnarios.com npx playwright test",
    "test:e2e:prod": "BASE_URL=https://www.cnarios.com npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allanRolle/cnarios-playwright.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/allanRolle/cnarios-playwright/issues"
  },
  "homepage": "https://github.com/allanRolle/cnarios-playwright#readme",
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^25.5.0"
  }
}
